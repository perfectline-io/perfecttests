{
  "name": "@perfectline-io/testing",
  "version": "0.3.3",
  "description": "Testing infrastructure for Bun + Next.js projects — Jest/Playwright config factories, health checks, and CI actions",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.build.json && cp -r src/health/templates dist/health/templates",
    "typecheck": "bunx tsc --noEmit"
  },
  "exports": {
    ".": "./dist/index.js",
    "./jest": "./dist/jest/config.js",
    "./jest/setup": "./dist/jest/setup.js",
    "./playwright": "./dist/playwright/config.js",
    "./playwright/fixtures": "./dist/playwright/fixtures.js",
    "./playwright/setup": "./dist/playwright/global-setup.js",
    "./mocks": "./dist/mocks/index.js",
    "./mocks/session": "./dist/mocks/session.js",
    "./mocks/platform": "./dist/mocks/platform.js",
    "./mocks/next-request": "./dist/mocks/next-request.js",
    "./helpers": "./dist/helpers/index.js",
    "./helpers/auth": "./dist/helpers/auth.js",
    "./helpers/db": "./dist/helpers/db.js",
    "./health": "./dist/health/index.js",
    "./health/collectors": "./dist/health/collectors/index.js"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@testing-library/jest-dom": ">=6.0.0",
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "@testing-library/jest-dom": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    },
    "dotenv": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.10",
    "@types/jest": "^30.0.0",
    "drizzle-orm": "^0.45.1",
    "jest": "^30.3.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "glob": "^13.0.6"
  }
}
